// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["mongoDb"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Project model - replaces ChatSession for better organization
model Project {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  title       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  published   Boolean   @default(false)
  publishedAt DateTime?
  deployedUrl String?
  deployedAt  DateTime?
  
  // Relations
  messages    Message[]
  files       File[]
  
  // Relation to User
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Stores individual messages in a chat conversation
model Message {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  externalId  String?   // Optional external ID from AI provider
  projectId   String    @db.ObjectId
  role        String    // 'user' or 'assistant'
  content     String    // Plain text content
  reasoning   String?   // Optional reasoning for assistant messages
  createdAt   DateTime  
  
  // Store all message parts as JSON directly in the message
  parts       Json?     // Array of message parts stored as JSON
  toolInvocations Json?  // Stored as JSON if needed
  experimental_attachments Json? // Array of attachments stored as JSON for Vercel AI SDK

  // Relations
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Stores files generated or modified in a project
model File {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String    @db.ObjectId
  path        String    // File path
  content     String    // File content
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, path])
}

// Keep existing models below

model ChatSession {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  // JSON object mapping file paths to their content, containing only LLM-generated or modified files
  files       Json
  // Conversation messages array (persisted full chat history)
  messages    Json
  // Optional title derived from the first ideashipArtifact tag
  title       String?
  createdAt   DateTime  @default(now())
  // Whether this project is publicly visible in the community
  published   Boolean   @default(false)
  // When the project was published (if it is published)
  publishedAt DateTime?
  // URL of the deployed site on S3/Spaces
  deployedUrl String?
  // When the site was last deployed
  deployedAt  DateTime?
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  name                String?
  email               String?       @unique
  emailVerified       DateTime?
  image               String?
  credits             Int           @default(5)
  // Chat credits spent today; reset daily
  chatCreditsSpent    Int           @default(0)
  // Timestamp of last reset of chat credits (UTC)
  chatCreditsLastReset DateTime?
  
  // Relations
  accounts            Account[]
  sessions            Session[]
  projects            Project[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

